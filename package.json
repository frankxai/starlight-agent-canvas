{
  "name": "starlight-agent-canvas",
  "version": "0.1.0",
  "private": true,
  "description": "OSS-first, MCP-native research and workflow canvas for agents, creators, and Starlight systems.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frankxai/starlight-agent-canvas.git"
  },
  "bugs": {
    "url": "https://github.com/frankxai/starlight-agent-canvas/issues"
  },
  "homepage": "https://github.com/frankxai/starlight-agent-canvas#readme",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm --filter @starlight-agent-canvas/core build && pnpm --filter @starlight-agent-canvas/web dev",
    "build": "pnpm --filter @starlight-agent-canvas/core build && pnpm --filter @starlight-agent-canvas/mcp build && pnpm --filter @starlight-agent-canvas/web build",
    "typecheck": "pnpm --filter @starlight-agent-canvas/core build && pnpm -r typecheck",
    "test": "pnpm --filter @starlight-agent-canvas/core test && pnpm --filter @starlight-agent-canvas/core build && pnpm --filter @starlight-agent-canvas/mcp test",
    "verify": "pnpm typecheck && pnpm test && pnpm build",
    "start": "pnpm build && pnpm --filter @starlight-agent-canvas/web start",
    "preview:prod": "pnpm build && pnpm --filter @starlight-agent-canvas/web start -p 3101",
    "setup:local": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "doctor:json": "node scripts/doctor.mjs --json",
    "first-success": "node scripts/first-success-contract.mjs",
    "first-success:json": "node scripts/first-success-contract.mjs --json",
    "adoption:report": "node scripts/adoption-report.mjs",
    "adoption:report:json": "node scripts/adoption-report.mjs --json",
    "install:proof": "node scripts/first-run-check.mjs",
    "first-run:check": "node scripts/first-run-check.mjs",
    "release:audit": "node scripts/release-audit.mjs",
    "canvas": "pnpm --filter @starlight-agent-canvas/core build && node scripts/canvas.mjs",
    "canvas:smoke": "pnpm --filter @starlight-agent-canvas/core build && node scripts/canvas-smoke.mjs",
    "test:e2e": "pnpm --filter @starlight-agent-canvas/web test:e2e",
    "seed:starlight": "pnpm --filter @starlight-agent-canvas/core build && node scripts/seed-starlight-canvas.mjs",
    "mcp:build": "pnpm --filter @starlight-agent-canvas/core build && pnpm --filter @starlight-agent-canvas/mcp build",
    "mcp:config": "node scripts/print-mcp-config.mjs",
    "mcp:install:codex": "node scripts/install-codex-mcp.mjs",
    "mcp:codex:smoke": "pnpm mcp:build && node scripts/codex-config-smoke.mjs",
    "mcp:smoke": "pnpm mcp:build && node packages/mcp/scripts/smoke.mjs",
    "mcp:start": "pnpm --filter @starlight-agent-canvas/mcp start"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
