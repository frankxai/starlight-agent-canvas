# Optional. Defaults to C:\Users\frank\.starlight\agent-canvas on Frank's Windows machine.
AGENT_CANVAS_HOME=

# Optional. Keep unset unless intentionally exposing the API beyond localhost.
AGENT_CANVAS_ALLOW_REMOTE=

# Optional. Used only when a URL-ingest request explicitly opts into Firecrawl.
FIRECRAWL_API_KEY=

# Optional future provider keys. v0.1 actions are deterministic and local by default.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
